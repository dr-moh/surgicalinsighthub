  {
    "id": 622,
    "specialty": "Orthopedic",
    "topic": "rush.docx",
    "question": "An asymptomatic patient is found to have a serum calcium level of 13.5 mg/dL. Which of the following medications should be avoided?",
    "options": {
      "A": "Bisphosphonates",
